---
import { siteConfig } from "@/config";
import { Github, Twitter, Linkedin } from "@lucide/astro";
---

<footer class="border-t border-border mt-20 py-10 px-10 lg:px-20">
    <div
        class="flex flex-col md:flex-row justify-between items-center gap-6"
    >
        <div class="flex flex-col items-center md:items-start gap-2">
            <span class="text-sm text-muted-foreground">
                &copy; {new Date().getFullYear()} {siteConfig.title}
            </span>
            <!-- <span class="text-xs text-muted-foreground">
                Built with <a
                    href="https://astro.build"
                    target="_blank"
                    rel="noreferrer"
                    class="hover:text-primary transition-colors">Astro</a
                >
            </span> -->
        </div>

        <div class="flex items-center gap-4">
            {
                siteConfig.socials.github && (
                    <a
                        href={siteConfig.socials.github}
                        target="_blank"
                        rel="noreferrer"
                        aria-label="GitHub"
                        class="text-muted-foreground hover:text-primary transition-colors"
                    >
                        <Github size={18} />
                    </a>
                )
            }
            {
                siteConfig.socials.twitter && (
                    <a
                        href={siteConfig.socials.twitter}
                        target="_blank"
                        rel="noreferrer"
                        aria-label="Twitter"
                        class="text-muted-foreground hover:text-primary transition-colors"
                    >
                        <Twitter size={18} />
                    </a>
                )
            }
            {
                siteConfig.socials.linkedin && (
                    <a
                        href={siteConfig.socials.linkedin}
                        target="_blank"
                        rel="noreferrer"
                        aria-label="LinkedIn"
                        class="text-muted-foreground hover:text-primary transition-colors"
                    >
                        <Linkedin size={18} />
                    </a>
                )
            }
            <!-- <a
                href="/feed.xml"
                class="text-sm text-muted-foreground hover:text-primary transition-colors"
            >
                Subscribe to RSS
            </a> -->
        </div>
    </div>
</footer>
