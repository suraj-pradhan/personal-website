---
import { getCollection } from "astro:content";
import {
    Terminal,
    GitMerge,
    Rocket,
    Cog,
    PenTool,
    Book,
    Sparkles,
    Github,
    Twitter,
    Linkedin,
} from "@lucide/astro";

import Separator from "./ui/Separator.astro";
import ActivityCard from "./about/ActivityCard.astro";
import DecorativeKanji from "./about/DecorativeKanji.astro";
import ProjectCard from "./ProjectCard.astro";
import Timeline from "./about/Timeline.astro";
import { siteConfig } from "@/config";

import mhrImage from "../assets/images/mhr.webp";
import frierenImage from "../assets/images/frieren.webp";
import pomImage from "../assets/images/pom.webp";
import neffexImage from "../assets/images/neffex.webp";

const timeline = [
    {
        year: "June 2024 - October 2025",
        title: "St. Mary's English Medium School",
        description: "Joined as a IT Support Executive",
        icon: Terminal,
    },
    {
        year: "November 2025 - Present",
        title: "Secured Security Solutions Pvt. Ltd.",
        description: "Joined as a Social Media and IT Executive",
        icon: GitMerge,
    },
    // {
    //     year: "Early 2022",
    //     title: "Opened my first issue on Github",
    //     description: "A bug issue on daisyUI",
    //     icon: Rocket,
    // },
    // {
    //     year: "Mid 2022",
    //     title: "Started building a ton of pet projects",
    //     description: "It was hard at first!",
    //     icon: Cog,
    // },
    // {
    //     year: "Late 2022",
    //     title: "Made a blog post",
    //     description: "Just for documenting my progress",
    //     icon: Book,
    // },
    // {
    //     year: "2023",
    //     title: "Started getting side hustle offers",
    //     description: "Along with my friends",
    //     icon: Terminal,
    // },
    // {
    //     year: "2024 - 2025",
    //     title: "Started my capstone",
    //     description: "App development with Flutter",
    //     icon: PenTool,
    // },
    // {
    //     year: "Now",
    //     title: "Building what's next",
    //     description: "Always learning, always shipping",
    //     icon: Sparkles,
    // },
];

const projects = [
    {
        title: "PCSO Lotto API",
        description:
            "A Node.js REST API that provides real-time PCSO lotto results via web scraping, with Redis-based caching and locking to ensure data freshness and prevent duplicate requests.",
        link: "https://github.com/jiseeeh/pcso-lotto-api",
        techStack: ["Node.js", "Cheerio", "Redis"],
    },
    {
        title: "U Do Note",
        description:
            "Flutter note-taking app integrating Spaced Repetition, Leitner, Feynman techniques, and etc with OCR via Google ML Kit and AI summarization using OpenAI.",
        link: "https://github.com/jiseeeh/u-do-note",
        techStack: ["Flutter", "Firebase", "OpenAI"],
    },
];

const entries = await getCollection("post");

let postsPerYear = 0;
if (entries.length > 0) {
    const years = entries.map((entry) => {
        const [, , y] = entry.data.date.split("/");
        return Number(y);
    });
    const minYear = Math.min(...years);
    const maxYear = Math.max(...years);
    const activeYears = Math.max(1, maxYear - minYear + 1);
    postsPerYear = Math.ceil(entries.length / activeYears);
}
---

<main class="page flex flex-col space-y-10">
    <section class="relative flex flex-col items-start gap-4">
        <span class="text-accent uppercase text-xs">// about the author</span>
        <h1 class="text-5xl">Tech Enthusiast, Design and Code</h1>
        <p>
            {siteConfig.author.bio}
        </p>

        {
            (siteConfig.socials.github ||
                siteConfig.socials.twitter ||
                siteConfig.socials.linkedin) && (
                <div class="flex items-center gap-4">
                    {siteConfig.socials.github && (
                        <a
                            href={siteConfig.socials.github}
                            target="_blank"
                            rel="noreferrer"
                            aria-label="GitHub"
                            class="text-muted-foreground hover:text-primary transition-colors"
                        >
                            <Github size={20} />
                        </a>
                    )}
                    {siteConfig.socials.twitter && (
                        <a
                            href={siteConfig.socials.twitter}
                            target="_blank"
                            rel="noreferrer"
                            aria-label="Twitter"
                            class="text-muted-foreground hover:text-primary transition-colors"
                        >
                            <Twitter size={20} />
                        </a>
                    )}
                    {siteConfig.socials.linkedin && (
                        <a
                            href={siteConfig.socials.linkedin}
                            target="_blank"
                            rel="noreferrer"
                            aria-label="LinkedIn"
                            class="text-muted-foreground hover:text-primary transition-colors"
                        >
                            <Linkedin size={20} />
                        </a>
                    )}
                </div>
            )
        }

        <span
            class="text-secondary -z-1 opacity-70 text-[10rem] absolute -top-16 -left-4 disable-select"
            aria-hidden="true">匠</span
        >
    </section>

    <section
        class="grid grid-cols-2 md:grid-cols-4 w-full border-l border-t border-border"
    >
        <DecorativeKanji title="2+" subTitle="Years of exp" kanji="歴" />
        <DecorativeKanji
            title={projects.length.toString()}
            subTitle="Projects Shipped"
            kanji="造"
        />
        <DecorativeKanji title="∞" subTitle="Coffees / day" kanji="杯" />
        <DecorativeKanji
            title={`~${postsPerYear}`}
            subTitle="Posts / year"
            kanji="筆"
        />
    </section>

    <div class="w-full h-1 bg-foreground"></div>

    <section>
        <section class="flex justify-between">
            <div class="size-5 border border-b-0 border-r-0 border-foreground">
            </div>
            <div
                class="size-5 border border-b-0 border-r-0 border-foreground rotate-90"
            >
            </div>
        </section>
        <section class="px-5 space-y-5">
            <p>
                I'm a backend developer who genuinely struggles to enjoy
                frontend work — CSS is not my love language. What I do care
                about is writing code that people can actually read: clear,
                honest, and purposeful.
            </p>
            <p>
                I'm still finding my footing — learning the craft of backend
                engineering, and getting curious about software design and
                architecture. How systems are shaped, and why some decisions age
                better than others.
            </p>
            <p>
                This blog is where I think out loud. Casual, occasionally
                technical, and posted whenever something finally clicks. No
                schedule — just thoughts worth putting into words.
            </p>
        </section>

        <section class="flex justify-between">
            <div
                class="size-5 border border-b-0 border-r-0 border-foreground -rotate-90"
            >
            </div>
            <div
                class="size-5 border border-b-0 border-r-0 border-foreground rotate-180"
            >
            </div>
        </section>
    </section>

    <Separator title="Currently" />

    <section class="grid grid-cols-1 md:grid-cols-2 gap-4 w-full">
        <ActivityCard
            imageSrc={mhrImage}
            imageAlt="Monster Hunter Rise wallpaper"
            label="Playing"
            title="Monster Hunter Rise"
            subtitle="Open-world action RPG"
        />
        <!-- https://wall.alphacoders.com/big.php?i=1367731  -->
        <ActivityCard
            imageSrc={frierenImage}
            imageAlt="Illustration of a chibi Frieren looking up"
            label="watching"
            title="Frieren: Beyond Journey's End"
            subtitle="Fantasy / Adventure"
        />
        <ActivityCard
            imageSrc={pomImage}
            imageAlt="Illustration of a brain shaped paper bills"
            label="reading"
            title="Psychology  of Money"
            subtitle="by Morgan Housel"
        />
        <!-- https://i.ytimg.com/vi/83RUhxsfLWs/maxresdefault.jpg -->
        <ActivityCard
            imageSrc={neffexImage}
            imageAlt="Logo of NEFFEX"
            label="listening"
            title="Grateful"
            subtitle="by NEFFEX"
        />
    </section>

    <Separator title="Projects" />

    <section class="flex flex-col gap-4">
        {
            projects.map((project) => (
                <ProjectCard
                    title={project.title}
                    description={project.description}
                    url={project.link}
                    techStack={project.techStack}
                />
            ))
        }
    </section>

    <Separator title="Journey" />

    <Timeline items={timeline} />

    <div
        class="flex items-center justify-center gap-4 text-muted-foreground text-sm pt-10 pb-4"
    >
        <div class="h-px w-full bg-foreground/10"></div>
        <span class="whitespace-nowrap uppercase tracking-widest">The End</span
        >
        <div class="h-px w-full bg-foreground/10"></div>
    </div>
</main>
